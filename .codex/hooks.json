{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"$(git rev-parse --show-toplevel)/.codex/hooks/notify.sh\" \"Codex\" \"Action requested\"",
            "timeout": 5,
            "statusMessage": "Sending notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"$(git rev-parse --show-toplevel)/.codex/hooks/notify.sh\" \"Codex\" \"Turn finished\"",
            "timeout": 5,
            "statusMessage": "Sending notification"
          }
        ]
      }
    ]
  }
}
