{
  "name": "@app/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "gw": "cd dist && cross-env NODE_OPTIONS=\"${NODE_OPTIONS:-} -r @app/config/env\" graphile-worker --crontab ../crontab --config ../graphile.config.js",
    "dev": "cd dist && cross-env NODE_OPTIONS=\"${NODE_OPTIONS:-} -r @app/config/env \" nodemon --watch ./ --exec 'graphile-worker --crontab ../crontab --config ../graphile.config.js'",
    "start": "yarn gw",
    "install-db-schema": "mkdir -p dist && yarn gw --schema-only"
  },
  "packageManager": "yarn@4.9.2",
  "dependencies": {
    "@app/config": "0.0.0",
    "@aws-sdk/client-sesv2": "^3.864.0",
    "@supabase/supabase-js": "^2.55.0",
    "@types/node": "^24.2.1",
    "@types/nodemailer": "^7.0.0",
    "chalk": "^5.5.0",
    "graphile-config": "^0.0.1-beta.17",
    "graphile-worker": "^0.16.6",
    "html-to-text": "^9.0.5",
    "lodash": "^4.17.21",
    "mjml": "^4.15.3",
    "mjml-core": "^4.15.3",
    "mjml-parser-xml": "^4.15.3",
    "nodemailer": "^7.0.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/html-to-text": "^9",
    "@types/lodash": "^4",
    "@types/mjml": "^4",
    "@types/mjml-core": "^4",
    "cross-env": "^7.0.3",
    "cross-env-shell": "^7.0.3",
    "nodemon": "^3.1.10"
  }
}
